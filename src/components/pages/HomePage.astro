---
import Base from '../../layouts/Base.astro';
import PostRow from '../PostRow.astro';
import WorkCard from '../WorkCard.astro';
import { getPosts, getProjects } from '../../lib/content';
import { SITE, localizedPath, type Lang } from '../../lib/site';

export interface Props {
  lang?: Lang;
}

const { lang = 'ko' } = Astro.props;
const allPosts = await getPosts(lang);
const posts = allPosts
  .filter((post) => ['thoughts', 'notes', 'video-notes'].includes(post.collection))
  .slice(0, 4);
const projects = (await getProjects(lang)).slice(0, 4);
const isEnglish = lang === 'en';
---
<Base title={SITE.name} active="About" lang={lang}>
  <section class="hero">
    <div class="container">
      <h1>{isEnglish ? 'Trying things' : '다양한 경험하기'}<br/><em>{isEnglish ? '& writing them down.' : '그리고 기록하기.'}</em></h1>
      <p class="bio">
        {isEnglish ? 'Hi, this is ' : '안녕하세요, '}
        <b>{SITE.author}</b>{isEnglish ? '. This blog collects experiments, projects, and notes.' : '입니다. 프로젝트, 배운 것, 일상의 기록을 남깁니다.'}
        {' '}<a href={localizedPath('/about', lang)}>{isEnglish ? 'Read more' : '더 읽기'} →</a>
      </p>
      <div class="meta">
        <a href={SITE.githubUrl}>{SITE.githubLabel}</a>
        <span class="dot"></span>
        <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
        <span class="dot"></span>
        <a href="/rss.xml">RSS</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="two-col">
        <div>
          <div class="section-head">
            <div>
              <div class="sub" style="margin-bottom:6px">THOUGHTS · NOTES · VIDEO NOTES</div>
              <h2>Posts</h2>
            </div>
            <a class="more" href={localizedPath('/posts', lang)}>all posts →</a>
          </div>
          {posts.map((post) => <PostRow post={post} lang={lang} />)}
        </div>
        <div>
          <div class="section-head">
            <div>
              <div class="sub" style="margin-bottom:6px">PROJECTS · VIDEOS</div>
              <h2>Works</h2>
            </div>
            <a class="more" href={localizedPath('/works', lang)}>all works →</a>
          </div>
          <div class="works-grid">
            {projects.map((project) => <WorkCard project={project} lang={lang} />)}
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
