---
import Base from '../../layouts/Base.astro';
import PostRow from '../PostRow.astro';
import WorkCard from '../WorkCard.astro';
import HarnessCard from '../HarnessCard.astro';
import { getPosts, getProjects, getHarness } from '../../lib/content';
import { SITE, localizedPath, type Lang } from '../../lib/site';

export interface Props {
  lang?: Lang;
}

const { lang = 'ko' } = Astro.props;
const allPosts = await getPosts(lang);
const posts = allPosts
  .filter((post) => ['thoughts', 'notes', 'video-notes'].includes(post.collection))
  .slice(0, 4);
const projects = (await getProjects(lang)).slice(0, 4);
const harness = (await getHarness(lang)).slice(0, 3);
const isEnglish = lang === 'en';
---
<Base title={SITE.name} lang={lang}>
  <section class="hero">
    <div class="container">
      <h1>{isEnglish ? 'Trying things' : '다양한 경험하기'}<br/><em>{isEnglish ? '& writing them down.' : '그리고 기록하기.'}</em></h1>
      <div class="meta">
        <a href={SITE.githubUrl}>{SITE.githubLabel}</a>
        <span class="dot"></span>
        <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
        <span class="dot"></span>
        <a href="/rss.xml">RSS</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="two-col">
        <div>
          <div class="section-head">
            <div>
              <div class="sub" style="margin-bottom:6px">THOUGHTS · NOTES · VIDEO NOTES</div>
              <h2>Posts</h2>
            </div>
            <a class="more" href={localizedPath('/posts', lang)}>all posts →</a>
          </div>
          {posts.map((post) => <PostRow post={post} lang={lang} />)}
        </div>
        <div>
          <div class="section-head">
            <div>
              <div class="sub" style="margin-bottom:6px">PROJECTS · VIDEOS</div>
              <h2>Projects</h2>
            </div>
            <a class="more" href={localizedPath('/projects', lang)}>all projects →</a>
          </div>
          <div class="works-grid">
            {projects.map((project) => <WorkCard project={project} lang={lang} />)}
          </div>
        </div>
      </div>
    </div>
  </section>

  {harness.length > 0 && (
    <section class="section last">
      <div class="container">
        <div class="section-head">
          <div>
            <div class="sub" style="margin-bottom:6px">SKILLS · AGENTS · MCP</div>
            <h2>Harness</h2>
          </div>
          <a class="more" href={localizedPath('/harness', lang)}>all harness →</a>
        </div>
        <div class="harness-grid">
          {harness.map((entry) => <HarnessCard entry={entry} lang={lang} />)}
        </div>
      </div>
    </section>
  )}
</Base>
