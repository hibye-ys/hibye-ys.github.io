---
import Base from '../../layouts/Base.astro';
import HarnessCard from '../HarnessCard.astro';
import { getHarness } from '../../lib/content';
import { SITE, type Lang } from '../../lib/site';

export interface Props {
  lang?: Lang;
}

const { lang = 'ko' } = Astro.props;
const entries = await getHarness(lang);

const categories = [...new Set(entries.map((e) => e.data.category))].sort();
const tags = [...new Set(entries.flatMap((e) => e.data.tags))].sort();

const labels = lang === 'ko'
  ? {
      title: 'Harness',
      lede: 'AI 사용에서 나온 부산물.',
      category: 'Category',
      tags: 'Tags',
      all: 'All',
      items: '항목',
      reset: '필터 초기화',
      empty: '선택한 필터에 해당하는 항목이 없습니다.',
      none: '아직 등록된 항목이 없습니다.',
    }
  : {
      title: 'Harness',
      lede: 'Byproducts of working with AI.',
      category: 'Category',
      tags: 'Tags',
      all: 'All',
      items: 'items',
      reset: 'Reset filters',
      empty: 'No items match the selected filters.',
      none: 'No items yet.',
    };
---
<Base title={`${labels.title} · ${SITE.name}`} active="Harness" lang={lang}>
  <section class="section" style="padding-top:48px">
    <div class="container">
      <div class="harness-head">
        <div class="sub" style="margin-bottom:6px">{entries.length} {labels.items}</div>
        <h2 class="harness-title">{labels.title}.</h2>
        <p class="harness-lede">{labels.lede}</p>
      </div>

      {entries.length === 0 ? (
        <p class="harness-empty">{labels.none}</p>
      ) : (
        <>
          <div class="harness-filter">
            <div class="harness-filter-row">
              <span class="harness-filter-label">{labels.category}</span>
              <div class="harness-seg" data-group="cat">
                <button type="button" class="on" data-v="all">{labels.all}</button>
                {categories.map((cat) => (
                  <button type="button" data-v={cat}>{cat}</button>
                ))}
              </div>
            </div>
            {tags.length > 0 && (
              <div class="harness-filter-row">
                <span class="harness-filter-label">{labels.tags}</span>
                <div class="harness-tags" data-group="tag">
                  {tags.map((tag) => (
                    <button type="button" class="harness-chip tag" data-v={tag}>{tag}</button>
                  ))}
                </div>
              </div>
            )}
            <div class="harness-filter-meta">
              <span><span data-count>{entries.length}</span> {labels.items}</span>
              <button type="button" class="harness-reset" data-reset>{labels.reset}</button>
            </div>
          </div>

          <div class="harness-grid" data-grid>
            {entries.map((entry) => <HarnessCard entry={entry} lang={lang} />)}
          </div>
          <p class="harness-empty" data-empty hidden>{labels.empty}</p>
        </>
      )}
    </div>
  </section>
</Base>

<script>
  const root = document.querySelector<HTMLElement>('.harness-filter');
  const grid = document.querySelector<HTMLElement>('[data-grid]');
  const emptyEl = document.querySelector<HTMLElement>('[data-empty]');
  const countEl = document.querySelector<HTMLElement>('[data-count]');

  if (root && grid && countEl) {
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.harness-card'));
    const state = { cat: 'all', tags: new Set<string>() };

    function readQuery() {
      const params = new URLSearchParams(window.location.search);
      const cat = params.get('cat');
      const tagParam = params.get('tags');
      const validCats = new Set(
        Array.from(root!.querySelectorAll<HTMLElement>('[data-group="cat"] [data-v]'))
          .map((el) => el.dataset.v ?? ''),
      );
      const validTags = new Set(
        Array.from(root!.querySelectorAll<HTMLElement>('[data-group="tag"] [data-v]'))
          .map((el) => el.dataset.v ?? ''),
      );
      if (cat && validCats.has(cat)) state.cat = cat;
      if (tagParam) {
        for (const t of tagParam.split(',').map((s) => s.trim()).filter(Boolean)) {
          if (validTags.has(t)) state.tags.add(t);
        }
      }
    }

    function writeQuery() {
      const params = new URLSearchParams(window.location.search);
      if (state.cat === 'all') params.delete('cat');
      else params.set('cat', state.cat);
      if (state.tags.size === 0) params.delete('tags');
      else params.set('tags', [...state.tags].join(','));
      const qs = params.toString();
      const next = window.location.pathname + (qs ? `?${qs}` : '');
      window.history.replaceState({}, '', next);
    }

    function syncUI() {
      root!.querySelectorAll<HTMLElement>('[data-group="cat"] [data-v]').forEach((el) => {
        el.classList.toggle('on', el.dataset.v === state.cat);
      });
      root!.querySelectorAll<HTMLElement>('[data-group="tag"] [data-v]').forEach((el) => {
        el.classList.toggle('on', state.tags.has(el.dataset.v ?? ''));
      });
    }

    function applyFilter() {
      let visible = 0;
      for (const card of cards) {
        const cat = card.dataset.cat ?? '';
        const tagAttr = card.dataset.tags ?? '';
        const cardTags = tagAttr ? tagAttr.split(',') : [];
        const catOk = state.cat === 'all' || cat === state.cat;
        const tagsOk = [...state.tags].every((t) => cardTags.includes(t));
        const show = catOk && tagsOk;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      }
      countEl!.textContent = String(visible);
      if (emptyEl) emptyEl.hidden = visible !== 0;
    }

    root.addEventListener('click', (event) => {
      const target = event.target as HTMLElement;
      const btn = target.closest<HTMLElement>('[data-v]');
      if (btn) {
        const group = btn.closest<HTMLElement>('[data-group]')?.dataset.group;
        const value = btn.dataset.v ?? '';
        if (group === 'cat') {
          state.cat = value;
        } else if (group === 'tag') {
          if (state.tags.has(value)) state.tags.delete(value);
          else state.tags.add(value);
        }
        syncUI();
        applyFilter();
        writeQuery();
        return;
      }
      if (target.closest('[data-reset]')) {
        state.cat = 'all';
        state.tags.clear();
        syncUI();
        applyFilter();
        writeQuery();
      }
    });

    readQuery();
    syncUI();
    applyFilter();
  }
</script>
