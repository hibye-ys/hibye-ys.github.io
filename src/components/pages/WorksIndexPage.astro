---
import Base from '../../layouts/Base.astro';
import WorkCard from '../WorkCard.astro';
import { getProjects } from '../../lib/content';
import { SITE, localizedPath, type Lang } from '../../lib/site';

export interface Props {
  lang?: Lang;
}

const { lang = 'ko' } = Astro.props;
const url = new URL(Astro.request.url);
const filter = url.searchParams.get('tag') || 'all';
const all = await getProjects(lang);
const filtered = filter === 'all' ? all : all.filter((project) => project.data.tag === filter);
const years = [...new Set(all.map((project) => project.data.year))].sort();
const span = years.length ? `${years[0]}-${years[years.length - 1]}` : '';
const tags = ['all', 'web', 'tool', 'writing'];
---
<Base title={`Projects · ${SITE.name}`} active="Projects" lang={lang}>
  <section class="section" style="padding-top:48px">
    <div class="container">
      <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:36px;flex-wrap:wrap;gap:16px">
        <div>
          <div class="sub" style="margin-bottom:6px">{all.length} PROJECTS{span && ` · ${span}`}</div>
          <h2 style="font-family:var(--display);font-style:italic;font-weight:400;font-size:56px;line-height:1;margin:0">Projects.</h2>
        </div>
        <div class="row-flex" style="gap:6px">
          {tags.map((tag) => <a href={tag === 'all' ? localizedPath('/projects', lang) : `${localizedPath('/projects', lang)}?tag=${tag}`} class={`tagchip ${tag === filter ? 'accent' : ''}`} style="text-decoration:none">{tag}</a>)}
        </div>
      </div>
      <div style="display:grid;grid-template-columns:repeat(3, 1fr);gap:28px">
        {filtered.map((project) => <WorkCard project={project} lang={lang} />)}
      </div>
    </div>
  </section>
</Base>
