---
import Base from '../../layouts/Base.astro';
import { SITE, type Lang } from '../../lib/site';

export interface Props {
  lang?: Lang;
}

const { lang = 'ko' } = Astro.props;
const isEnglish = lang === 'en';
---
<Base title={`About · ${SITE.name}`} active="About" lang={lang}>
  <section class="section" style="padding-top:48px">
    <div class="container">
      <div style="display:grid;grid-template-columns:260px 1fr;gap:56px">
        <div>
          <div style="aspect-ratio:3/4;border-radius:10px;border:1px solid var(--rule);background:var(--bg-2)"></div>
          <div style="margin-top:16px;font-family:var(--mono);font-size:12px;color:var(--ink-3);line-height:1.9">
            <div><a href={SITE.githubUrl}>→ github</a></div>
            <div><a href={`mailto:${SITE.email}`}>→ email</a></div>
            <div><a href="/rss.xml">→ rss</a></div>
          </div>
        </div>
        <div>
          <h1 style="font-family:var(--display);font-weight:400;font-size:72px;line-height:1;letter-spacing:-.02em;margin:0">
            About <em style="font-style:italic;color:var(--accent)">me</em>.
          </h1>
          <div style="margin-top:24px;font-family:var(--serif-reader);font-size:16px;line-height:1.65;color:var(--ink-2);max-width:640px">
            {isEnglish ? (
              <>
                <p>I use this blog to record projects, experiments, and things I learn along the way.</p>
                <p>The Korean posts are shown as fallback until matching English versions are written.</p>
              </>
            ) : (
              <>
                <p>프로젝트, 실험, 배우는 과정에서 남기고 싶은 것들을 기록합니다.</p>
                <p>이 블로그는 다양한 경험을 쌓고 다시 꺼내 보기 위한 개인 공간입니다.</p>
              </>
            )}
          </div>
          <h3 style="font-family:var(--display);font-style:italic;font-weight:400;font-size:28px;margin:40px 0 12px">Now</h3>
          <ul style="margin:0;padding-left:20px;font-family:var(--serif-reader);font-size:14px;color:var(--ink-2);line-height:1.7">
            <li>{isEnglish ? 'Rebuilding this blog with Astro' : 'Astro로 블로그 전체 리빌드'}</li>
            <li>{isEnglish ? 'Writing notes from small experiments' : '작은 실험에서 배운 것 기록하기'}</li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</Base>
