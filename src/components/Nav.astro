---
import { SITE, localizedPath, switchLocalePath, type Lang } from '../lib/site';

export interface Props {
  active?: 'About' | 'Posts' | 'Works';
  lang?: Lang;
}

const { active = 'About', lang = 'ko' } = Astro.props;
const items: Array<'About' | 'Posts' | 'Works'> = ['About', 'Posts', 'Works'];
const pathFor = (item: string) => item === 'About' ? '/about' : item === 'Posts' ? '/posts' : '/works';
const hrefFor = (item: string) => localizedPath(pathFor(item), lang);
const homeHref = localizedPath('/', lang);
const koHref = switchLocalePath(Astro.url.pathname, 'ko');
const enHref = switchLocalePath(Astro.url.pathname, 'en');
---
<header class="container">
  <nav class="nav">
    <a href={homeHref} class="brand" style="text-decoration:none">{SITE.name}<em>.</em></a>
    <div class="nav-actions">
      <ul>
        {items.map((item) => (
          <li><a href={hrefFor(item)} class={active === item ? 'active' : ''}>{item}</a></li>
        ))}
      </ul>
      <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle color theme">
        <span class="theme-light">Light</span>
        <span>/</span>
        <span class="theme-dark-label">Dark</span>
      </button>
      <div class="lang" aria-label="Language switcher">
        <a href={koHref} class={lang === 'ko' ? 'active-lang' : ''}>KO</a>
        <span>/</span>
        <a href={enHref} class={lang === 'en' ? 'active-lang' : ''}>EN</a>
      </div>
    </div>
  </nav>
</header>
<script>
  const root = document.documentElement;
  const themeToggle = document.getElementById('theme-toggle');

  function applyTheme(theme: 'light' | 'dark') {
    root.classList.toggle('theme-dark', theme === 'dark');
    root.dataset.theme = theme;
    localStorage.setItem('theme', theme);
  }

  themeToggle?.addEventListener('click', () => {
    applyTheme(root.dataset.theme === 'dark' ? 'light' : 'dark');
  });
</script>
